{
    "info": {
        "name": "Neptune EMS Prepaid API",
        "description": "Postman Collection for the Neptune EMS Prepaid API testing. Features endpoints for Customer Detail, Recharge, Daily Consumption, and Live Data.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Customer Detail (MASTERDATA)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/x-www-form-urlencoded",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "urlencoded",
                    "urlencoded": [
                        {
                            "key": "TXN_NAME",
                            "value": "MASTERDATA",
                            "type": "text"
                        },
                        {
                            "key": "DATA",
                            "value": "",
                            "type": "text"
                        },
                        {
                            "key": "SITECODE",
                            "value": "{{SITECODE}}",
                            "type": "text"
                        },
                        {
                            "key": "username",
                            "value": "{{username}}",
                            "type": "text"
                        },
                        {
                            "key": "password",
                            "value": "{{password}}",
                            "type": "text"
                        }
                    ]
                },
                "url": {
                    "raw": "{{baseUrl}}/service.asmx/liveEmsTransaction",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "service.asmx",
                        "liveEmsTransaction"
                    ]
                }
            }
        },
        {
            "name": "2. Recharge Meter (RECHARGE)",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/x-www-form-urlencoded",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "urlencoded",
                    "urlencoded": [
                        {
                            "key": "TXN_NAME",
                            "value": "RECHARGE",
                            "type": "text"
                        },
                        {
                            "key": "DATA",
                            "value": "{\"CA_no\":\"1\",\"Reference_No\":\"617639\",\"Payment_Mode\":\"CASH\",\"TRN_Amt\":1,\"To_Account\":\"ICICI\"}",
                            "type": "text"
                        },
                        {
                            "key": "SITECODE",
                            "value": "{{SITECODE}}",
                            "type": "text"
                        },
                        {
                            "key": "username",
                            "value": "{{username}}",
                            "type": "text"
                        },
                        {
                            "key": "password",
                            "value": "{{password}}",
                            "type": "text"
                        }
                    ]
                },
                "url": {
                    "raw": "{{baseUrl}}/service.asmx/liveEmsTransaction",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "service.asmx",
                        "liveEmsTransaction"
                    ]
                }
            }
        },
        {
