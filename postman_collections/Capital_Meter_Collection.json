    ],
    "item": [
        {
            "name": "1. Consumer Meter - Get Meter Details & Readings (Grid)",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "apikey",
                        "value": "{{apiKey}}"
                    }
                ],
                "url": {
                    "raw": "{{gridBaseUrl}}/integration_api/v1/consumer/meter?site_id={{gridSiteId}}&consumer_id={{consumerId}}",
                    "host": [
                        "{{gridBaseUrl}}"
                    ],
                    "path": [
                        "integration_api",
                        "v1",
                        "consumer",
                        "meter"
                    ],
                    "query": [
                        {
                            "key": "site_id",
                            "value": "{{gridSiteId}}"
                        },
                        {
                            "key": "consumer_id",
                            "value": "{{consumerId}}"
                        }
                    ]
                },
                "description": "Returns full meter details including balance, EB/DG readings (kWh and kVAh), current load, cut status, recharge history, and billing type."
            },
            "response": [
                {
                    "name": "Success Response",
                    "status": "OK",
                    "code": 200,
                    "_postman_previewlanguage": "json",
                    "body": "{\n    \"status\": \"T\",\n    \"message\": \"success\",\n    \"count\": 1,\n    \"data\": {\n        \"consumer_id\": \"2000171289\",\n        \"consumer_name\": \"ramesh\",\n        \"site_id\": \"xyz\",\n        \"meter_no\": \"sr-1100000000000221\",\n        \"unit_no\": \"UNIT-PC-1\",\n        \"cut_status\": \"NORMAL\",\n        \"last_recharge_amount\": \"11.0\",\n        \"last_recharge_timestamp\": \"1681410600000\",\n        \"current_source\": \"EB\",\n        \"status\": \"UP\",\n        \"balance\": \"0.0\",\n        \"current_load\": \"0.0\",\n        \"grid_reading_kwh\": \"130.0\",\n        \"grid_reading_kvah\": \"130.0\",\n        \"dg_reading_kwh\": \"130.0\",\n        \"dg_reading_kvah\": \"130.0\"\n    }\n}"
                }
            ]
        },
        {
            "name": "2. Consumer Meter - Get Meter Details & Readings (DG)",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "apikey",
                        "value": "{{apiKey}}"
                    }
                ],
                "url": {
                    "raw": "{{dgBaseUrl}}/integration_api/v1/consumer/meter?site_id={{dgSiteId}}&consumer_id={{consumerId}}",
                    "host": [
                        "{{dgBaseUrl}}"
                    ],
                    "path": [
                        "integration_api",
                        "v1",
                        "consumer",
                        "meter"
                    ],
                    "query": [
                        {
                            "key": "site_id",
                            "value": "{{dgSiteId}}"
                        },
                        {
                            "key": "consumer_id",
                            "value": "{{consumerId}}"
                        }
                    ]
                },
                "description": "Same as endpoint 1 but hitting the DG (Diesel Generator) server for DG-specific readings."
            },
            "response": []
        },
        {
            "name": "3. Consumer Balance - Get Balance Only",
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "apikey",
                        "value": "{{apiKey}}"
                    }
                ],
                "url": {
                    "raw": "{{gridBaseUrl}}/integration_api/v1/consumer/balance?site_id={{gridSiteId}}&consumer_id={{consumerId}}",
                    "host": [
                        "{{gridBaseUrl}}"
                    ],
                    "path": [
                        "integration_api",
                        "v1",
                        "consumer",
                        "balance"
                    ],
                    "query": [
                        {
                            "key": "site_id",
                            "value": "{{gridSiteId}}"
                        },
                        {
                            "key": "consumer_id",
                            "value": "{{consumerId}}"
                        }
                    ]
                },
                "description": "Returns only the consumer's current balance. Also used for user authentication/validation."
