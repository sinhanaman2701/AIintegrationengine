                }
            ]
        },
        {
            "name": "4. Consumer Do Recharge",
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "apikey",
                        "value": "{{apiKey}}"
                    }
                ],
                "url": {
                    "raw": "{{gridBaseUrl}}/integration_api/v1/consumer/recharge?consumer_id={{consumerId}}&amount=100&transaction_id=TEST-TXN-001&payment_type=ONLINE&site_id={{gridSiteId}}",
                    "host": [
                        "{{gridBaseUrl}}"
                    ],
                    "path": [
                        "integration_api",
                        "v1",
                        "consumer",
                        "recharge"
                    ],
                    "query": [
                        {
                            "key": "consumer_id",
                            "value": "{{consumerId}}"
                        },
                        {
                            "key": "amount",
                            "value": "100"
                        },
                        {
                            "key": "transaction_id",
                            "value": "TEST-TXN-001"
                        },
                        {
                            "key": "payment_type",
                            "value": "ONLINE"
                        },
                        {
                            "key": "site_id",
                            "value": "{{gridSiteId}}"
                        }
                    ]
                },
                "description": "Processes a prepaid meter recharge. Requires consumer_id, amount, transaction_id, payment_type, and site_id."
            },
            "response": [
                {
                    "name": "Success Response",
                    "status": "OK",
                    "code": 200,
