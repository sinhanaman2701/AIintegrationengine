            "value": "http://dg.smartprepaidmeters.com"
        },
        {
            "key": "apiKey",
            "value": "YW5hcm9ja19hZG1pbjpjYXBpdGFsQDE5NzM="
        },
        {
            "key": "gridSiteId",
